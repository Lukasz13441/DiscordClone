<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Discord-like Friends Page</title>
    <link rel="stylesheet" href="~/css/manage-friends.css">
</head>
<body>

    <div class="discord-grid">

        <!-- Left Sidebar -->
        <aside class="sidebar">
            <div class="logo">DF</div>
            <nav class="icons">
                <div class="icon">🏠</div>
                <div class="icon">💬</div>
                <div class="icon">👥</div>
                <div class="icon">⚙️</div>
            </nav>
        </aside>

        <!-- Main content -->
        <section class="main">
            

                <!-- Requests -->
                <div class="panel">
                    <h2>Incoming Requests</h2>
                    <ul>
                        <li class="request">
                            <div>
                                <strong>Michael</strong>
                                <div class="handle">mike#2222</div>
                            </div>
                            <div class="actions">
                                <button class="btna">Accept</button>
                                <button class="btna ghost">Reject</button>
                            </div>
                        </li>
                    </ul>
                </div>

                <!-- Add Friend -->
                <div class="panel">
                    <h2>Add Friend</h2>
                    <input type="text" placeholder="username#1234">
                    <button class="btna primary">Send Request</button>

                    <h3 style="margin-top:20px;">Other Users</h3>
                    <ul>
                        <li>Anna <span class="handle">anna#8888</span></li>
                        <li>Chris <span class="handle">chris#4444</span></li>
                    </ul>
                </div>

            </div>
        </section>

    </div>

</body>
</html>
